# API base URL for the mobile app.
#
# Production (Vercel): use same-origin proxy — cookies do not survive cross-site
# fetch (mobile.vercel.app → railway.app) on Safari / mobile Chrome.
VITE_API_URL=/api
#
# Local dev: Vite proxies /api → http://localhost:4000 (see vite.config.ts).
# VITE_API_URL=/api
#
# Direct API (no proxy — auth cookies may fail cross-origin locally too):
# VITE_API_URL=http://localhost:4000
