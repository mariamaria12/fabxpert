# Supabase Postgres connection string (pooler URL — same as packages/db DATABASE_URL)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# JWT — generate a secret with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REMEMBER_EXPIRY_ADMIN=30d
JWT_REMEMBER_EXPIRY_EMPLOYEE=365d
JWT_SESSION_EXPIRY=1d

PORT=4000
NODE_ENV=development

# Web app origin allowed for credentialed CORS requests
WEB_APP_URL="http://localhost:3000"

# Mobile PWA origin allowed for credentialed CORS requests
MOBILE_APP_URL="http://localhost:3001"

# E2E tests — dedicated Postgres database (NEVER use dev/prod DATABASE_URL)
# Use a separate Supabase project, a local Postgres database, or a dedicated schema (e.g. ?schema=fabxpert_e2e)
# TEST_DATABASE_URL must differ from DATABASE_URL — the test runner refuses to start if they match.
TEST_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=fabxpert_e2e"
# Optional: direct connection for prisma migrate deploy in tests (defaults to TEST_DATABASE_URL)
TEST_DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=fabxpert_e2e"
