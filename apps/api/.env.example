# =============================================================================
# REQUIRED IN PRODUCTION (Railway service for apps/api)
# =============================================================================

# Supabase Postgres — session pooler (port 5432). Used by the app at runtime.
# Supabase dashboard → Settings → Database → Connection string → Session pooler
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase Postgres — direct connection for Prisma Migrate (migrate deploy on start).
# Same host as session pooler on newer Supabase projects; required by schema directUrl.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET="replace-with-a-long-random-secret"

# JWT cookie lifetimes (supports ms/s/m/h/d suffix, e.g. 30d, 1d)
JWT_REMEMBER_EXPIRY_ADMIN=30d
JWT_REMEMBER_EXPIRY_EMPLOYEE=365d
JWT_SESSION_EXPIRY=1d

# Allowed CORS origins (comma-separated, no wildcard). Credentialed cookies require exact match.
# Production example (both Vercel frontends in one var):
#   WEB_APP_URL="https://app.fabxpert.ro,https://mobil.fabxpert.ro"
WEB_APP_URL="http://localhost:3000"

# Optional extra CORS origin — convenient for local dev (mobile PWA on :3001).
# In production you can omit this if both URLs are in WEB_APP_URL above.
MOBILE_APP_URL="http://localhost:3001"

# Railway injects PORT automatically — do not hardcode in production.
# Local dev fallback when unset:
PORT=4000

# Set to production on Railway
NODE_ENV=development

# =============================================================================
# PRODUCTION SEED ONLY (manual one-time — NOT set on Railway deploy)
# Run locally: pnpm --filter @fabxpert/db db:seed:prod
# Creates EmployeeRoles, Activities, and the first ADMIN user only.
# =============================================================================

ADMIN_SEED_EMAIL="replace-with-admin-email"
ADMIN_SEED_PASSWORD="replace-with-a-strong-password"

# =============================================================================
# DEV / LOCAL SEED ONLY (packages/db prisma/seed.ts — never use against prod)
# =============================================================================

# Optional dev admin (also created by db:seed if set)
# ADMIN_SEED_* above is shared; re-used by dev seed.

# Optional single test employee for mobile dev login
EMPLOYEE_SEED_EMAIL="replace-with-employee-email"
EMPLOYEE_SEED_PASSWORD="replace-with-a-strong-password"

# Shared password for the 5 dummy EMPLOYEE test accounts in dev seed
TEST_USERS_SEED_PASSWORD="replace-with-a-strong-password"

# =============================================================================
# DEV / E2E TEST ONLY — do NOT set on Railway production
# =============================================================================

# Dedicated Postgres for e2e tests (must differ from DATABASE_URL)
TEST_DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=fabxpert_e2e"

# Optional direct URL for e2e migrations (defaults to TEST_DATABASE_URL)
TEST_DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=fabxpert_e2e"
