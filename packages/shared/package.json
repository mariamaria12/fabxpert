{
  "name": "@fabxpert/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dto/company.dto": {
      "types": "./dist/dto/company.dto.d.ts",
      "default": "./dist/dto/company.dto.js"
    },
    "./dto/project.dto": {
      "types": "./dist/dto/project.dto.d.ts",
      "default": "./dist/dto/project.dto.js"
    },
    "./dto/user.dto": {
      "types": "./dist/dto/user.dto.d.ts",
      "default": "./dist/dto/user.dto.js"
    },
    "./dto/timesheet.dto": {
      "types": "./dist/dto/timesheet.dto.d.ts",
      "default": "./dist/dto/timesheet.dto.js"
    },
    "./dto/pagination.dto": {
      "types": "./dist/dto/pagination.dto.d.ts",
      "default": "./dist/dto/pagination.dto.js"
    },
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
