# Supabase Postgres connection string
# Supabase is used as managed Postgres only — Auth, RLS, Storage are not used in the MVP.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Find this in your Supabase project: Settings > Database > Connection string (URI mode)
DATABASE_URL="postgresql://USER:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?schema=public"
