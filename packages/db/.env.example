# Supabase Postgres connection strings
# Supabase is used as managed Postgres only — Auth, RLS, Storage are not used in the MVP.
# Find both strings in: Supabase dashboard → Settings → Database → Connection string

# Session-mode pooler (port 5432) — used by the app at runtime
# Username format: postgres.PROJECT_REF
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Direct connection for Prisma Migrate — same host/port as session pooler for newer Supabase projects
# (Old projects used db.PROJECT_REF.supabase.co:5432 — that format no longer applies here)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Seed: initial admin account (used only by prisma/seed.ts — never hardcode real credentials here)
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="Fabxpert123!"
