// Prisma schema for FabXpert
// Database: Supabase (Postgres) — used as managed Postgres only.
// See docs/architecture.md for the domain model and design decisions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  EMPLOYEE
}

enum ProjectStatus {
  CIORNA           // Draft
  IN_OFERTARE      // Quotation
  CASTIGAT         // Awarded
  IN_PROIECTARE    // Engineering
  IN_PRODUCTIE     // In Production
  PREGATIT_LIVRARE // Ready for Delivery
  LIVRAT           // Delivered
  FINALIZAT        // Completed
  SUSPENDAT        // On Hold
  ANULAT           // Cancelled
}

// ---------------------------------------------------------------------------
// EmployeeRole
// Admin-managed lookup table for job roles (e.g. "Sudor", "Vopsitor").
// Not an enum — rows are managed at runtime, not compile-time.
// ---------------------------------------------------------------------------

model EmployeeRole {
  id        String    @id @default(uuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  persons Person[]

  visibleForProjects Project[]

  @@map("employee_roles")
}

// ---------------------------------------------------------------------------
// Activity
// Admin-managed lookup table for work activities (e.g. "Sudare", "Vopsire").
// Not an enum — rows are managed at runtime, not compile-time.
// Same structural pattern as EmployeeRole.
// ---------------------------------------------------------------------------

model Activity {
  id        String    @id @default(uuid())
  name      String    @unique
  color     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  timesheets Timesheet[]

  @@map("activities")
}

// ---------------------------------------------------------------------------
// Person
// Represents an employee (name, contact info). Not every Person has a User.
// ---------------------------------------------------------------------------

model Person {
  id         String    @id @default(uuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  // Optional link to a job role — can be assigned after creation.
  employeeRoleId String?
  employeeRole   EmployeeRole? @relation(fields: [employeeRoleId], references: [id])

  // A User always maps to exactly one Person; back-reference is optional.
  user User?

  // Timesheets where this Person is the subject of the logged time.
  timesheets Timesheet[]

  @@map("persons")
}

// ---------------------------------------------------------------------------
// User
// Represents a login account. Always linked to exactly one Person.
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Required: every User must reference exactly one Person.
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])

  // Timesheets created/entered by this User (may differ from the Person whose time is logged).
  timesheets Timesheet[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Company
// Represents a client — the beneficiary of fabrication projects.
// Not a platform tenant; not a supplier (MVP scope).
// ---------------------------------------------------------------------------

model Company {
  id                  String    @id @default(uuid())
  name                String
  taxCode             String?
  tradeRegistryNumber String?
  registeredAddress   String?
  phone               String?
  deliveryAddress     String?
  legalRepresentative String?
  email               String?
  contactPerson       String?
  contactPersonPhone  String?
  color               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  projects Project[]

  @@map("companies")
}

// ---------------------------------------------------------------------------
// Project
// Belongs to exactly one Company (the client). No multi-company association in MVP.
// ---------------------------------------------------------------------------

model Project {
  id                String        @id @default(uuid())
  name              String
  code              String        @unique
  status            ProjectStatus @default(CIORNA)
  startDate         DateTime?
  dueDate           DateTime?
  readyForExecution Boolean       @default(false)
  color             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  timesheets Timesheet[]

  visibleForRoles EmployeeRole[]

  @@map("projects")
}

// ---------------------------------------------------------------------------
// Timesheet
// Records time logged by a Person against a Project.
// personId  — whose time is being logged.
// userId    — who created/entered the record (may differ, e.g. admin logging on behalf).
// activityId — optional; can be assigned after the entry is created.
// workDate  — calendar day the work was done (stored as DateTime at local midnight; time ignored).
// durationMinutes — whole minutes worked (e.g. 90 = 1h30m).
// ---------------------------------------------------------------------------

model Timesheet {
  id              String    @id @default(uuid())
  workDate        DateTime  @default(now())
  durationMinutes Int
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  personId String
  person   Person @relation(fields: [personId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id])

  @@map("timesheets")
}
